# Supabase — для локалі значення друкує `pnpm db:start`
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-local-anon-key

# Google OAuth — для локального входу через Google (config.toml читає ці змінні).
# Беруться з Google Cloud Console (OAuth 2.0 Client). Можна лишити порожніми,
# якщо локально Google-вхід не тестуєш.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
